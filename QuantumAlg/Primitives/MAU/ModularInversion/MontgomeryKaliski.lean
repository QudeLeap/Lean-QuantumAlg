  uEven_msb :
    x.active = true -> x.v.val ≠ 0 ->
      x.u.val.testBit (0 : Nat) = false ->
        x.sCoeff.val.testBit (Fin.last tail.succ).val = false
  uEven_double :
    x.active = true -> x.v.val ≠ 0 ->
