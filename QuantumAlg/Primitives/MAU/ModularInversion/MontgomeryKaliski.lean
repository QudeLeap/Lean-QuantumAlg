  calc
    (coeffWorkSubVFromUStep n counterWidth x).1.1.sCoeff.val.testBit
        bit.val =
        (coeffWorkAddVIntoUStep n counterWidth
          (coeffWorkSubVFromUStep n counterWidth x)).1.1.sCoeff.val.testBit
            bit.val := by
      simpa [coeffAdderSCoeffValueWord_get_testBit] using hadd.symm
    _ = x.1.1.sCoeff.val.testBit bit.val := by
      rw [hcancel]

