  rw [EncodedBit.get_flip_self]
  rw [EncodedBit.toffoliStep_get_of_target_ne active u scratchA u
    (Ne.symm hUScratchA)]
  rw [EncodedBit.get_flip_self]
  cases u.get x <;> simp

