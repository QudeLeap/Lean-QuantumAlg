      (liftedUGreaterBranchCodeToScratchStep n counterWidth) :=
  { encoding := registersWithComparisonWorkEncoding n counterWidth
    program :=
      BaseGateProgram.prodLeft
        (m := (registerEncoding n counterWidth).width)
        (n := (comparisonWorkEncoding n).width)
        (uGreaterBranchCodeToScratchProgram n counterWidth)
    realizes := by
      change BaseGateProgram.Realizes
        (registersWithComparisonWorkEncoding n counterWidth)
        (BaseGateProgram.prodLeft
          (m := (registerEncoding n counterWidth).width)
          (n := (comparisonWorkEncoding n).width)
          (uGreaterBranchCodeToScratchProgram n counterWidth))
        (fun x : RegistersWithComparisonWork n counterWidth =>
          (uGreaterBranchCodeToScratchStep n counterWidth x.1, x.2))
      simpa [registersWithComparisonWorkEncoding] using
        BaseGateProgram.Realizes.prodLeft
          (right := comparisonWorkEncoding n)
          (uGreaterBranchCodeToScratch_realizes n counterWidth) }

