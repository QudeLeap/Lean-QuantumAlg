      (fun vbit =>
        liftRegisterBit_liftRegisterBit_wire_ne tail.succ counterWidth
          (RegisterBits.vValueBit tail.succ counterWidth vbit)
          (RegisterBits.counterBit tail.succ counterWidth
            (WireAddress.littleEndianWire bit))
