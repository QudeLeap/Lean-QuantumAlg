      (uGreaterBranchCodeToScratchStep n counterWidth) where
  encoding := registerEncoding n counterWidth
  program := uGreaterBranchCodeToScratchProgram n counterWidth
  realizes := uGreaterBranchCodeToScratch_realizes n counterWidth

/-- Comparison-conditioned `uGreater` branch-code staging preserves the active
flag. -/
