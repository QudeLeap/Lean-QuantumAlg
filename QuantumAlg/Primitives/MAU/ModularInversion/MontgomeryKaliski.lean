    simpa [vBit, low, liftCoeffAdderStateBitToFullRoundWork,
      BinaryLabelEncoding.prodLeftBit] using hvLow
  change EncodedBit.toffoliStep uBit vBit target x = target.flip x
  unfold EncodedBit.toffoliStep
  rw [if_pos]
  simp [hu, hv]

