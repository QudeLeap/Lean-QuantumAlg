  fun x =>
    coeffWorkAuxRMul2CyclicShiftStep n counterWidth
      (coeffWorkAuxVDiv2CyclicShiftStep n counterWidth x)

/-- Same-Circuit witness for the scratchA-controlled `v / 2`, `r * 2`
