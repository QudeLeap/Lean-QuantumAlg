  rw [coeffWorkAuxActiveShiftDispatchPrefixStep_get_active,
    coeffWorkAuxActiveShiftDispatchPrefixStep_get_scratchA, h]

/-- The auxiliary-bit Kaliski shift dispatch preserves equality between the
