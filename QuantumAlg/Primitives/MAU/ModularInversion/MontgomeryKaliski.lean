    (RegisterBits.scratchABit n counterWidth).get x
  rw [vEvenBranchCodeToScratchStep_get_scratchA_clean n counterWidth uIndex
    vIndex y hcompareAfterWrite]
  dsimp [y]
  rw [activeScratchBToHistoryStep_get_scratchA]
