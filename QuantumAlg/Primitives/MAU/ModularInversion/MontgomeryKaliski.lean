theorem coeffWorkSubUFromVStep_get_scratchB
    (n counterWidth : Nat)
    (x : RegistersWithCoeffAdderWork n counterWidth) :
    (coeffAdderScratchBBit n counterWidth).get
        (coeffWorkSubUFromVStep n counterWidth x) =
