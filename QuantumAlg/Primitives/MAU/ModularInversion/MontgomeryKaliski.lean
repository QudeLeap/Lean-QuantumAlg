      tail.succ counterWidth low)
    (coeffAdderVBit_coeffAdderScratchBBit_wire_ne
      tail.succ counterWidth low)
    (Ne.symm (coeffAdderActiveBit_coeffAdderComparisonCarryBit_wire_ne
