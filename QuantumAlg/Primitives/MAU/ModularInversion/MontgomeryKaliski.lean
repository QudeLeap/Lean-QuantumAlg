  EncodedBit.GateSpec.stepList
    (fullRoundWorkActiveOddOddLatchThenSelectedOrCompareCarriedDispatchGates
      tail counterWidth comparisonIndex historyIndex workIndex)

/-- Same-Circuit witness for latching the active-guarded odd-odd selector
before running the latched selected/compare-carried body dispatcher. -/
def fullRoundWorkActiveOddOddLatchThenSelectedOrCompareCarriedDispatchSameCircuit
    (tail counterWidth : Nat) (comparisonIndex : Fin tail.succ)
    (historyIndex : Fin (2 * tail.succ))
    (workIndex : Fin (counterWidth - 1)) :
    BaseGateSameCircuitWitness (RegistersWithFullRoundWork tail.succ counterWidth)
