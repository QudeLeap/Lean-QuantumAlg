    coeffWorkCompareSelectorSelectedOddDataPathStep_get_comparisonCarryPrefix_clean
    (n counterWidth : Nat) (bit : Fin n) (workBit : Fin (n - 1))
    (x : Registers n counterWidth) (work : CoeffAdderWork n)
