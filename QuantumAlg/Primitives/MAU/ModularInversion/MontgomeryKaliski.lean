    (liftedCoeffAdderCarryInBit n counterWidth).get
        (coeffWorkSubVFromUStep n counterWidth x) =
        (liftedCoeffAdderCarryInBit n counterWidth).get
          (coeffWorkAddVIntoUStep n counterWidth
            (coeffWorkSubVFromUStep n counterWidth x)) := by
