      tail counterWidth comparisonIndex workIndex p x
      (fixedRoundModeControlledSemanticReadoutPrefixState_certAt_of_bezout_bounds
        tail counterWidth comparisonIndex workIndex p x hfinal bounds)

/-- Combined fixed-round agreement between the fresh-workspace corrected
semantic readout fold and the canonical trace: the final source-shaped state and
the final stored history bits both match the trace produced by the selected
`2n` schedule. -/
structure FixedRoundModeControlledSemanticReadoutAgreement
    (tail counterWidth : Nat) (comparisonIndex : Fin tail.succ)
    (workIndex : Fin (counterWidth - 1)) (p x : Word tail.succ) : Prop where
  finish :
    modeControlledSemanticReadoutFoldStateRoundState tail.succ counterWidth
        (fixedRoundModeControlledSemanticReadoutPrefixState
          tail counterWidth comparisonIndex workIndex
          (rnsl17MontgomerySchedule tail.succ).rounds
          (initialModeControlledSemanticReadoutFoldState
            tail.succ counterWidth p x)) =
      (Trace.ofInput tail.succ p.val x.val).finish
  history :
    fixedRoundModeControlledSemanticReadoutFinalHistory
        tail counterWidth comparisonIndex workIndex p x =
      (Trace.ofInput tail.succ p.val x.val).history

/-- Package the fresh-workspace fixed-round final state and final stored-history
readout equalities into one trace-agreement witness. -/
theorem fixedRoundModeControlledSemanticReadoutAgreement
    (tail counterWidth : Nat) (comparisonIndex : Fin tail.succ)
    (workIndex : Fin (counterWidth - 1)) (p x : Word tail.succ)
    (certAt :
      ∀ priorIndex : Fin (rnsl17MontgomerySchedule tail.succ).rounds,
          ModeControlledSemanticStepReadoutCertificate tail counterWidth
            comparisonIndex
            (RoundState.fixedRoundHistoryIndex tail.succ priorIndex)
            (fixedRoundModeControlledSemanticReadoutPrefixState
              tail counterWidth comparisonIndex workIndex priorIndex.val
              (initialModeControlledSemanticReadoutFoldState
                tail.succ counterWidth p x)).registers) :
    FixedRoundModeControlledSemanticReadoutAgreement
      tail counterWidth comparisonIndex workIndex p x where
  finish :=
    fixedRoundModeControlledSemanticReadoutPrefixState_full_finish
      tail counterWidth comparisonIndex workIndex p x certAt
  history :=
    fixedRoundModeControlledSemanticReadoutFinalHistory_eq_traceHistory
      tail counterWidth comparisonIndex workIndex p x certAt

/-- Package the fresh-workspace fixed-round trace agreement from concrete
per-slot Bezout bounds and the final comparison-index condition. -/
theorem fixedRoundModeControlledSemanticReadoutAgreement_of_bezout_bounds
    (tail counterWidth : Nat) (comparisonIndex : Fin tail.succ)
    (workIndex : Fin (counterWidth - 1)) (p x : Word tail.succ)
    (hfinal : comparisonIndex.val + 1 = tail.succ)
    (bounds :
      FixedRoundModeControlledSemanticReadoutPrefixBezoutBounds
        tail counterWidth comparisonIndex workIndex p x) :
    FixedRoundModeControlledSemanticReadoutAgreement
      tail counterWidth comparisonIndex workIndex p x :=
  fixedRoundModeControlledSemanticReadoutAgreement
    tail counterWidth comparisonIndex workIndex p x
    (fixedRoundModeControlledSemanticReadoutPrefixState_certAt_of_bezout_bounds
      tail counterWidth comparisonIndex workIndex p x hfinal bounds)

/-- Arithmetic bridge predicate: the corrected trace-side residue equals the
unit inverse for the supplied staged input. -/
def CorrectedResidueMatchesUnitInverse {n p : Nat}
    (trace : Trace n) (u : (ZMod p)ˣ) : Prop :=
  trace.correctedInverseResidue p = inverseResidue u

/-- A corrected residue that multiplies with the staged unit to `1` is exactly
the staged inverse residue. -/
theorem correctedResidueMatchesUnitInverse_of_mul_input_eq_one {n p : Nat}
    (trace : Trace n) (u : (ZMod p)ˣ)
    (hmul : trace.correctedInverseResidue p * (u : ZMod p) = 1) :
    trace.CorrectedResidueMatchesUnitInverse u := by
  change trace.correctedInverseResidue p = inverseResidue u
  have hunit : (u : ZMod p) * inverseResidue u = 1 := by
    simp [inverseResidue]
  calc
    trace.correctedInverseResidue p
        = trace.correctedInverseResidue p * 1 := by
      ring
    _ = trace.correctedInverseResidue p *
          ((u : ZMod p) * inverseResidue u) := by
      rw [hunit]
    _ = (trace.correctedInverseResidue p * (u : ZMod p)) *
          inverseResidue u := by
      ring
    _ = 1 * inverseResidue u := by
      rw [hmul]
    _ = inverseResidue u := by
      ring

/-- Arithmetic bridge predicate for a scaled endpoint: the corrected trace-side
residue equals the explicitly scaled inverse of the supplied staged input. -/
def CorrectedResidueMatchesScaledUnitInverse {n p : Nat}
    (trace : Trace n) (scale : ZMod p) (u : (ZMod p)ˣ) : Prop :=
  trace.correctedInverseResidue p = scaledInverseResidue scale u

theorem correctedResidueMatchesScaledUnitInverse_of_mul_input_eq {n p : Nat}
    (trace : Trace n) (scale : ZMod p) (u : (ZMod p)ˣ)
    (hmul : trace.correctedInverseResidue p * (u : ZMod p) = scale) :
    trace.CorrectedResidueMatchesScaledUnitInverse scale u := by
  change trace.correctedInverseResidue p = scaledInverseResidue scale u
  exact eq_scaledInverseResidue_of_mul_input_eq
    (trace.correctedInverseResidue p) scale u hmul

/-- Final fixed-trace correction bridge into the explicitly scaled endpoint.
For the RNSL/HJN Montgomery route, the scale is the fixed source factor. -/
theorem ofInput_correctedResidueMatchesScaledUnitInverse_of_final_state
    (n p x : Nat) (u : (ZMod p)ˣ)
    (hx : (x : ZMod p) = (u : ZMod p))
    (hfinish : (ofInput n p x).finish.u = 1) :
    (ofInput n p x).CorrectedResidueMatchesScaledUnitInverse
      (-((2 : ZMod p) ^ (2 * n))) u := by
  apply correctedResidueMatchesScaledUnitInverse_of_mul_input_eq
  calc
    (ofInput n p x).correctedInverseResidue p * (u : ZMod p)
        = (ofInput n p x).correctedInverseResidue p * (x : ZMod p) := by
      rw [hx]
    _ = -((2 : ZMod p) ^ (2 * n)) :=
      ofInput_correctedInverseResidue_mul_input_eq_neg_pow_of_final_state
        n p x hfinish

/-- Unit-input form of the final fixed-trace correction bridge into the scaled
endpoint. -/
theorem ofUnitInput_correctedResidueMatchesScaledUnitInverse_of_final_state
    (n p : Nat) [NeZero p] (u : (ZMod p)ˣ)
    (hfinish : (ofUnitInput n p u).finish.u = 1) :
    (ofUnitInput n p u).CorrectedResidueMatchesScaledUnitInverse
      (-((2 : ZMod p) ^ (2 * n))) u := by
  change
    (ofInput n p (u : ZMod p).val).CorrectedResidueMatchesScaledUnitInverse
      (-((2 : ZMod p) ^ (2 * n))) u
  exact ofInput_correctedResidueMatchesScaledUnitInverse_of_final_state
    n p (u : ZMod p).val u
    (by simp)
    (by simpa [ofUnitInput] using hfinish)

/-- Final fixed-trace correction bridge into the staged raw-inverse endpoint.
The source-level correction factor is proved separately; this wrapper keeps the
normalization from that factor to `1` explicit. -/
theorem ofInput_correctedResidueMatchesUnitInverse_of_final_state
    (n p x : Nat) (u : (ZMod p)ˣ)
    (hx : (x : ZMod p) = (u : ZMod p))
    (hfinish : (ofInput n p x).finish.u = 1)
    (hnormalize : -((2 : ZMod p) ^ (2 * n)) = 1) :
    (ofInput n p x).CorrectedResidueMatchesUnitInverse u := by
  have hscaled :
      (ofInput n p x).CorrectedResidueMatchesScaledUnitInverse
        (-((2 : ZMod p) ^ (2 * n))) u :=
    ofInput_correctedResidueMatchesScaledUnitInverse_of_final_state
      n p x u hx hfinish
  change (ofInput n p x).correctedInverseResidue p = inverseResidue u
  change
    (ofInput n p x).correctedInverseResidue p =
      scaledInverseResidue (-((2 : ZMod p) ^ (2 * n))) u at hscaled
  calc
    (ofInput n p x).correctedInverseResidue p
        = scaledInverseResidue (-((2 : ZMod p) ^ (2 * n))) u := hscaled
    _ = scaledInverseResidue (1 : ZMod p) u := by
      rw [hnormalize]
    _ = inverseResidue u := by
      simp [scaledInverseResidue]

/-- Unit-input form of the fixed-trace correction bridge.  The canonical
`ZMod` representative discharges the staged input representative equality; the
final-state and normalization premises remain explicit. -/
theorem ofUnitInput_correctedResidueMatchesUnitInverse_of_final_state
    (n p : Nat) [NeZero p] (u : (ZMod p)ˣ)
    (hfinish : (ofUnitInput n p u).finish.u = 1)
    (hnormalize : -((2 : ZMod p) ^ (2 * n)) = 1) :
    (ofUnitInput n p u).CorrectedResidueMatchesUnitInverse u := by
  change
    (ofInput n p (u : ZMod p).val).CorrectedResidueMatchesUnitInverse u
  exact ofInput_correctedResidueMatchesUnitInverse_of_final_state
    n p (u : ZMod p).val u
    (by simp)
    (by simpa [ofUnitInput] using hfinish)
    hnormalize

/-- Overwrite-style staged compute step obtained by filling the inverse scratch
from the corrected trace-side residue.  The downstream reversible/additive
scratch interface is packaged separately. -/
def stageWithCorrectedInverse {n p : Nat}
    (trace : Trace n) (s : StageState p) : StageState p where
  input := s.input
  target := s.target
  inverseScratch := trace.correctedInverseResidue p
  flag := s.flag

theorem stageWithCorrectedInverse_eq_computeInverse_of_matches {n p : Nat}
    (trace : Trace n) (s : StageState p)
    (hmatch : trace.CorrectedResidueMatchesUnitInverse s.input) :
    trace.stageWithCorrectedInverse s = StageState.computeInverse s := by
  cases s with
  | mk input target inverseScratch flag =>
    change trace.correctedInverseResidue p = inverseResidue input at hmatch
    change
      ({ input := input
         target := target
         inverseScratch := trace.correctedInverseResidue p
         flag := flag } : StageState p) =
        { input := input
          target := target
          inverseScratch := inverseResidue input
          flag := flag }
    rw [hmatch]

theorem stageWithCorrectedInverse_eq_stageWithScaledInverse_of_matches
    {n p : Nat} (trace : Trace n) (scale : ZMod p) (s : StageState p)
    (hmatch : trace.CorrectedResidueMatchesScaledUnitInverse scale s.input) :
    trace.stageWithCorrectedInverse s = stageWithScaledInverse scale s := by
  cases s with
  | mk input target inverseScratch flag =>
    change trace.correctedInverseResidue p = scaledInverseResidue scale input
      at hmatch
    change
      ({ input := input
         target := target
         inverseScratch := trace.correctedInverseResidue p
         flag := flag } : StageState p) =
        { input := input
          target := target
          inverseScratch := scaledInverseResidue scale input
          flag := flag }
    rw [hmatch]

end Trace

